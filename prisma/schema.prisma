generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String           @id @default(cuid())
  email         String?          @unique
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  emailVerified DateTime?
  image         String?
  name          String?
  password      String?
  gmailLastSynced DateTime? 
  accounts      Account[]
  applications  JobApplication[]
  folders       JobApplicationFolder[]
  sessions        Session[]
  currentFolderId String?
  currentFolder   JobApplicationFolder? @relation("UserCurrentFolder", fields: [currentFolderId], references: [id], onDelete: SetNull)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum JobApplicationStatus {
  Applied
  Interview
  Offer
  Rejected_Direct          @map("Rejected (Direct)")
  Rejected_After_Interview @map("Rejected (After Interview)")
}

model JobApplication {
  id              String               @id @default(cuid())
  company         String
  position        String
  status          JobApplicationStatus
  appliedDate     DateTime
  location        String?
  notes           String?
  userId          String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  externalJobId   String?
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentFolderId String?
  currentFolder   JobApplicationFolder? @relation("JobApplicationCurrentFolder", fields: [currentFolderId], references: [id], onDelete: SetNull)
}

model JobApplicationFolder {
  id                          String            @id @default(cuid())
  userId                      String
  user                        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderName                  String
  usersWithThisAsCurrentFolder User[]           @relation("UserCurrentFolder")
  applicationsWithThisFolder   JobApplication[] @relation("JobApplicationCurrentFolder")

  @@unique([userId, folderName])
}
