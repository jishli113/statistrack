# Database (Supabase: use pooler URL for runtime; direct URL for migrations — see SUPABASE_SETUP.md)
DATABASE_URL=
DIRECT_URL=

# NextAuth — generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3002

# OAuth (see OAUTH_SETUP.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secured cron route (POST /api/cron/check-emails)
CRON_SECRET=

# Upstash Redis — queue + rate limit (see ARCHITECTURE.md)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Claude — email parsing (see app/evalutation.ts)
CLAUDE_API_KEY=
EMAIL_PARSE_PROMPT=
MAX_TOKENS=
